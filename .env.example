# Copy to .env and fill in. Everything has safe defaults for local dry-run
# except ANTHROPIC_API_KEY, which the advisor and llm-trader need.

# Anthropic API key (https://console.anthropic.com). Without it, the advisor
# writes a neutral posture and the llm-trader refuses to start.
ANTHROPIC_API_KEY=

# Claude model for both services.
CLAUDE_MODEL=claude-sonnet-5

# Freqtrade API credentials (local dashboards at :8080 / :8081).
# FT_JWT_SECRET must be at least 32 characters.
FT_API_PASSWORD=change-me-locally
FT_JWT_SECRET=local-dev-jwt-secret-not-for-production-use
FT_WS_TOKEN=local-dev-ws-token-not-for-production-use

# How often the advisor refreshes the market posture (hours).
ADVISOR_INTERVAL_HOURS=4
