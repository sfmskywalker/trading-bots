{
    "bot_name": "llm-bot",
    "dry_run": true,
    "dry_run_wallet": 10000,
    "trading_mode": "spot",
    "margin_mode": "",
    "max_open_trades": 3,
    "stake_currency": "USDT",
    "stake_amount": 1000,
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "EUR",
    "cancel_open_orders_on_exit": false,
    "unfilledtimeout": {
        "entry": 10,
        "exit": 10,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exchange": {
        "name": "binance",
        "key": "",
        "secret": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [],
        "pair_blacklist": [
            ".*(UP|DOWN|BULL|BEAR)/USDT",
            "(USDC|FDUSD|TUSD|USDP|DAI|BUSD|USD1|AEUR|EUR|EURI|GBP|TRY|BRL|ARS|COP|XUSD)/USDT",
            "(WBTC|WBETH|WETH)/USDT"
        ]
    },
    "pairlists": [
        {
            "method": "VolumePairList",
            "number_assets": 60,
            "sort_key": "quoteVolume",
            "min_value": 5000000,
            "refresh_period": 1800
        },
        {"method": "AgeFilter", "min_days_listed": 30}
    ],
    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": ""
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret_key": "overridden-by-env",
        "ws_token": "overridden-by-env",
        "CORS_origins": [],
        "username": "freqtrader",
        "password": "overridden-by-env"
    },
    "db_url": "sqlite:////freqtrade/user_data/tradesv3.dryrun.sqlite",
    "initial_state": "running",
    "force_entry_enable": true,
    "internals": {
        "process_throttle_secs": 5
    }
}
